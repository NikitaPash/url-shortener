# Load-test environment overlay — copy to the SUT for the headline CAPACITY run.
#
# WHY: when the load generator hits the API through nginx (the only way to reach a
# remote SUT, since :8080 is bound to 127.0.0.1), nginx overwrites X-Real-IP with
# the generator's single IP, so the per-IP limiter throttles the whole benchmark
# (the previous remote runs were 100% HTTP 429). The limiter is an application
# POLICY ceiling, not a CAPACITY ceiling — so we raise it for the capacity test
# only, and document that we did. Run a SEPARATE test with default limits to show
# the limiter working as designed.
#
# Apply on the SUT, e.g.:
#   set -a; . ./.env; . ./loadtest/.env.loadtest.example; set +a
#   docker compose up -d go-api    # recreate with the raised limits
#
# (Or hit go-api:8080 directly from an LG in the same VPC, where X-Real-IP rotation
#  works and these overrides are unnecessary — see LOAD_TEST_PLAN.md §1b.)

RATE_LIMIT_REDIRECT=1000000
RATE_LIMIT_API=1000000
RATE_LIMIT_AUTH=1000000

# Optional: give go-api more Postgres headroom for the cache-miss path under load.
# DB_MAX_CONNS=50