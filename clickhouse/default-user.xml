<clickhouse>
  <users>
    <default>
      <!-- Password tracks CLICKHOUSE_PASSWORD (passed in as CLICKHOUSE_DEFAULT_PASSWORD
           by docker-compose). The clickhouse-consumer and seeded data connect as this
           user. A non-"magic" env name is used so the image's built-in CLICKHOUSE_PASSWORD
           provisioning doesn't fight this mounted config. Empty value = no password. -->
      <password from_env="CLICKHOUSE_DEFAULT_PASSWORD"/>
      <networks>
        <ip>::/0</ip>
      </networks>
    </default>
  </users>
</clickhouse>