# python-agent local development environment.
# Copy to .env and adjust for your local setup.
# These values are for running the service directly (uvicorn / make run), not via Docker Compose.

CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_DATABASE=shortener
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash-lite
JWT_SECRET=change_me_in_production
# Same Redis instance/DB the Go API writes its JWT logout denylist to.
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0
MAX_QUERY_ROWS=1000
QUERY_TIMEOUT_SECONDS=10
JAEGER_ENDPOINT=localhost:4318
METRICS_PORT=9093
