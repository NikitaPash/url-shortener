# Root .env — docker-compose orchestration variables.
# Each application service also has its own .env in its directory for local development.
# Copy this file to .env and fill in real values before running docker-compose.

# ── Postgres ──────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=change_me_in_production

# ── Shared secrets (used by multiple services) ────────────────────────────────
JWT_SECRET=change_me_in_production

# ── Admin account ─────────────────────────────────────────────────────────────
# Seeded on go-api startup. Gates the Admin Panel in the UI (the AI Analytics
# page is open to all logged-in users). The env values are authoritative: on
# restart the account is (re)created and its password reset to ADMIN_PASSWORD.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_me_in_production

# ── ClickHouse ────────────────────────────────────────────────────────────────
# default user is used by the clickhouse-consumer (needs write access).
CLICKHOUSE_DATABASE=shortener
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=change_me_in_production
# Dedicated read-only user the python-agent connects as (cannot write).
CLICKHOUSE_ANALYST_PASSWORD=change_me_in_production

# ── Kafka (used by go-api and clickhouse-consumer) ────────────────────────────
KAFKA_TOPIC=link_clicks

# ── AI analytics agent (Google Gemini) ───────────────────────────────────────
# Required for the Analytics page / AI agent. Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash-lite

# ── Misc ──────────────────────────────────────────────────────────────────────
BASE_URL=http://localhost
GRAFANA_PASSWORD=admin
