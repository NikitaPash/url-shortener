# Root .env — variables for `docker compose` (the whole stack). Copy to .env:
#   cp .env.example .env
#
# LOCAL DEV   the defaults below work as-is. Add a GEMINI_API_KEY only if you want
#             the AI Analytics page. Leave the "Domain & TLS" section untouched.
#             Then: docker compose up -d
#
# PRODUCTION  set every *_PASSWORD and JWT_SECRET to a strong unique value
#             (openssl rand -hex 32), set ADMIN_* + GEMINI_API_KEY, and fill the
#             "Domain & TLS" section. Full guide: deployment.md.

# ── Postgres ──────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=change_me_in_production

# ── Shared secrets (used by multiple services) ────────────────────────────────
JWT_SECRET=change_me_in_production

# ── Admin account ─────────────────────────────────────────────────────────────
# Seeded on go-api startup. Gates the Admin Panel in the UI (the AI Analytics
# page is open to all logged-in users). The env values are authoritative: on
# restart the account is (re)created and its password reset to ADMIN_PASSWORD.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_me_in_production

# ── ClickHouse ────────────────────────────────────────────────────────────────
# default user is used by the clickhouse-consumer (needs write access).
CLICKHOUSE_DATABASE=shortener
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=change_me_in_production
# Dedicated read-only user the python-agent connects as (cannot write).
CLICKHOUSE_ANALYST_PASSWORD=change_me_in_production

# ── Kafka (used by go-api and clickhouse-consumer) ────────────────────────────
KAFKA_TOPIC=link_clicks

# ── AI analytics agent (Google Gemini) ───────────────────────────────────────
# Required for the Analytics page / AI agent. Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash-lite

# ── GeoIP (optional — used only by ./scripts/fetch-geoip.sh, NOT by docker-compose) ───
# A free MaxMind GeoLite2 license key lets scripts/fetch-geoip.sh download the country
# database baked into the go-api image (powers the country analytics/map).
# How to get one (free, ~3 min):
#   1. Sign up at https://www.maxmind.com/en/geolite2/signup — you'll accept the
#      GeoLite2 end-user agreement and answer a couple of usage questions.
#   2. Confirm the verification email, set a password, then log in at
#      https://www.maxmind.com/en/account
#   3. In the left sidebar open "Manage License Keys" → "Generate new license key".
#   4. Give it a name (e.g. "url-shortener"). If it asks whether the key is for
#      geoipupdate 3.1.1 or newer, answering "No" is fine for this project.
#   5. Click generate, then copy the key it shows (displayed only once) below.
# Leaving this blank just means the click "country" column stays empty.
MAXMIND_LICENSE_KEY=

# ── Misc ──────────────────────────────────────────────────────────────────────
# Public base URL for short links, Prometheus external-url and Grafana.
# Local: http://localhost. Production with TLS: https://<your DOMAIN below>.
BASE_URL=http://localhost
GRAFANA_PASSWORD=admin

# ── Domain & TLS (production deploy only — leave default/blank for local HTTP) ──
# Which nginx config to mount. Local HTTP keeps the default; the DigitalOcean TLS
# deploy sets this to the HTTPS config (used with docker-compose.prod.yml).
NGINX_CONF=./nginx/nginx.conf
# Public domain for HTTPS. Easiest zero-cost option: a nip.io name built from the
# Droplet's reserved IP with dots as dashes, e.g. 203-0-113-5.nip.io — it resolves
# publicly, so Let's Encrypt issues a real, trusted certificate. (Or use your own
# registered domain with an A record pointing at the reserved IP.)
DOMAIN=

# Set to 1 to use Let's Encrypt's staging CA while testing TLS (avoids the strict
# rate limits on the production CA). Use 0 for real certificates.
STAGING=0
# Prod convenience: lets a bare `docker compose ...` include the TLS overlay (no
# -f flags). Set ONLY on the server — uncommenting it locally breaks `up` (no cert).
# COMPOSE_FILE=docker-compose.yml:docker-compose.prod.yml
