# go-api local development environment.
# Copy to .env and adjust for your local setup.
# These values are for running the service directly (go run / make run), not via Docker Compose.

PORT=8080
DATABASE_URL=postgres://shortener:change_me@localhost:5432/shortener?sslmode=disable
DB_MAX_CONNS=10
DB_MIN_CONNS=2
# Set false in prod if migrations run as a separate job/init container.
RUN_MIGRATIONS=true
JWT_SECRET=change_me_in_production
JWT_EXPIRY=24h
BASE_URL=http://localhost:8080
# Seeded admin account (gates the Admin Panel in the UI; analytics is open).
# Leave both blank to skip seeding. Env values are authoritative on restart.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_me_in_production
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0
GEOIP_DB_PATH=data/GeoLite2-Country.mmdb
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC=link_clicks
RATE_LIMIT_AUTH=10
RATE_LIMIT_REDIRECT=100
RATE_LIMIT_API=30
JAEGER_ENDPOINT=localhost:4318
METRICS_PORT=9091
