# clickhouse-consumer local development environment.
# Copy to .env and adjust for your local setup.
# These values are for running the service directly (go run / make run), not via Docker Compose.

KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC=link_clicks
KAFKA_GROUP_ID=clickhouse-writers
CLICKHOUSE_ADDR=localhost:9000
CLICKHOUSE_DATABASE=shortener
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
BATCH_SIZE=1000
FLUSH_INTERVAL=5s
JAEGER_ENDPOINT=localhost:4318
METRICS_PORT=9094
