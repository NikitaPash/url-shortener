{
  "uid": "link-leaderboard",
  "title": "Link Performance Leaderboard",
  "tags": ["url-shortener"],
  "timezone": "utc",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-7d", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "user_id",
        "label": "User",
        "type": "query",
        "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
        "query": "SELECT DISTINCT user_id FROM shortener.clicks ORDER BY user_id",
        "refresh": 2,
        "includeAll": true,
        "allValue": "%",
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "multi": false,
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "table",
      "title": "Link Performance Leaderboard",
      "description": "Top 20 links by click volume with detailed stats",
      "gridPos": { "h": 18, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT short_id, count() AS total_clicks, uniq(ip) AS unique_visitors, min(timestamp) AS first_click, max(timestamp) AS last_click, countIf(device = 'mobile') AS mobile_clicks, countIf(is_bot = 1) AS bot_clicks FROM shortener.clicks WHERE $__timeFilter(timestamp) AND user_id LIKE '$user_id' GROUP BY short_id ORDER BY total_clicks DESC LIMIT 20",
          "editorMode": "code",
          "format": 1
        }
      ],
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "total_clicks", "desc": true }],
        "footer": { "show": false }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "inspect": false
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "total_clicks" },
            "properties": [
              { "id": "displayName", "value": "Total Clicks" },
              { "id": "custom.width", "value": 140 },
              {
                "id": "custom.cellOptions",
                "value": { "type": "gauge", "mode": "basic" }
              },
              { "id": "color", "value": { "mode": "continuous-BlPu" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "unique_visitors" },
            "properties": [
              { "id": "displayName", "value": "Unique Visitors" },
              { "id": "custom.width", "value": 140 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "first_click" },
            "properties": [
              { "id": "displayName", "value": "First Click" },
              { "id": "unit", "value": "dateTimeAsIso" },
              { "id": "custom.width", "value": 180 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "last_click" },
            "properties": [
              { "id": "displayName", "value": "Last Click" },
              { "id": "unit", "value": "dateTimeAsIso" },
              { "id": "custom.width", "value": 180 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "mobile_clicks" },
            "properties": [
              { "id": "displayName", "value": "Mobile" },
              { "id": "custom.width", "value": 90 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "bot_clicks" },
            "properties": [
              { "id": "displayName", "value": "Bots" },
              { "id": "custom.width", "value": 90 },
              { "id": "color", "value": { "mode": "thresholds" } },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "yellow", "value": 5 },
                    { "color": "red", "value": 20 }
                  ]
                }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "short_id" },
            "properties": [
              { "id": "displayName", "value": "Short ID" },
              { "id": "custom.width", "value": 120 }
            ]
          }
        ]
      }
    }
  ]
}
