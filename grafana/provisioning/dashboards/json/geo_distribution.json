{
  "uid": "geo-distribution",
  "title": "Geographic Distribution",
  "tags": ["url-shortener"],
  "timezone": "utc",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-7d", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "user_id",
        "label": "User",
        "type": "query",
        "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
        "query": "SELECT DISTINCT user_id FROM shortener.clicks ORDER BY user_id",
        "refresh": 2,
        "includeAll": true,
        "allValue": "%",
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "multi": false,
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "geomap",
      "title": "Geographic Distribution",
      "description": "Click volume by country",
      "gridPos": { "h": 14, "w": 16, "x": 0, "y": 0 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT country, count() AS clicks FROM shortener.clicks WHERE $__timeFilter(timestamp) AND user_id LIKE '$user_id' AND country != '' GROUP BY country ORDER BY clicks DESC",
          "editorMode": "code",
          "format": 0
        }
      ],
      "options": {
        "view": { "id": "zero", "lat": 20, "lon": 0, "zoom": 2 },
        "controls": { "showZoom": true, "mouseWheelZoom": true },
        "layers": [
          {
            "type": "markers",
            "name": "Clicks by country",
            "config": {
              "style": {
                "size": { "fixed": 5, "min": 2, "max": 15, "field": "clicks" },
                "color": { "field": "clicks" },
                "opacity": 0.7,
                "symbol": { "fixed": "circle" }
              },
              "showLegend": true
            },
            "location": { "mode": "lookup", "lookupField": "country", "gazetteer": "public/gazetteer/countries.json" },
            "tooltip": true
          }
        ]
      },
      "fieldConfig": {
        "defaults": { "color": { "mode": "continuous-GrYlRd" } },
        "overrides": []
      }
    },
    {
      "id": 2,
      "type": "piechart",
      "title": "Top Countries",
      "description": "Click share by country (top 10)",
      "gridPos": { "h": 14, "w": 8, "x": 16, "y": 0 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT country, count() AS clicks FROM shortener.clicks WHERE $__timeFilter(timestamp) AND user_id LIKE '$user_id' AND country != '' GROUP BY country ORDER BY clicks DESC LIMIT 10",
          "editorMode": "code",
          "format": 0
        }
      ],
      "transformations": [
        { "id": "rowsToFields", "options": { "nameField": "country", "valueField": "clicks" } }
      ],
      "options": {
        "pieType": "pie",
        "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] },
        "tooltip": { "mode": "single" }
      },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" } },
        "overrides": []
      }
    }
  ]
}
