{
  "uid": "bot-traffic",
  "title": "Bot Traffic Ratio",
  "tags": ["url-shortener"],
  "timezone": "utc",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-7d", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "user_id",
        "label": "User",
        "type": "query",
        "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
        "query": "SELECT DISTINCT user_id FROM shortener.clicks ORDER BY user_id",
        "refresh": 2,
        "includeAll": true,
        "allValue": "%",
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "multi": false,
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Bot Traffic %",
      "description": "Percentage of clicks identified as bot traffic",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT round(countIf(is_bot = 1) / count() * 100, 1) AS bot_percentage FROM shortener.clicks WHERE $__timeFilter(timestamp) AND user_id LIKE '$user_id'",
          "editorMode": "code",
          "format": 0
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 30 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Total Clicks",
      "description": "Total click events in selected time range",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT count() AS total FROM shortener.clicks WHERE $__timeFilter(timestamp) AND user_id LIKE '$user_id'",
          "editorMode": "code",
          "format": 0
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Human Clicks",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT countIf(is_bot = 0) AS human FROM shortener.clicks WHERE $__timeFilter(timestamp) AND user_id LIKE '$user_id'",
          "editorMode": "code",
          "format": 0
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": { "color": { "fixedColor": "green", "mode": "fixed" } },
        "overrides": []
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Bot Clicks",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT countIf(is_bot = 1) AS bot FROM shortener.clicks WHERE $__timeFilter(timestamp) AND user_id LIKE '$user_id'",
          "editorMode": "code",
          "format": 0
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": { "color": { "fixedColor": "red", "mode": "fixed" } },
        "overrides": []
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Human vs Bot Traffic Over Time",
      "description": "Stacked view of human and bot click volume",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 6 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT $__timeInterval(timestamp) AS time, countIf(is_bot = 0) AS human, countIf(is_bot = 1) AS bot FROM shortener.clicks WHERE $__timeFilter(timestamp) AND user_id LIKE '$user_id' GROUP BY time ORDER BY time ASC",
          "editorMode": "code",
          "format": 1
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 20,
            "lineWidth": 2,
            "drawStyle": "line",
            "stacking": { "mode": "normal", "group": "A" }
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "human" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "bot" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          }
        ]
      }
    }
  ]
}
