{
  "uid": "browser-breakdown",
  "title": "Browser Breakdown",
  "tags": ["url-shortener"],
  "timezone": "utc",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "30s",
  "time": { "from": "now-7d", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "user_id",
        "label": "User",
        "type": "query",
        "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
        "query": "SELECT DISTINCT user_id FROM shortener.clicks ORDER BY user_id",
        "refresh": 2,
        "includeAll": true,
        "allValue": "%",
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "multi": false,
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "piechart",
      "title": "Browser Distribution",
      "description": "Share of traffic by browser (bots excluded)",
      "gridPos": { "h": 14, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT browser, count() AS clicks FROM shortener.clicks WHERE $__timeFilter(timestamp) AND user_id LIKE '$user_id' AND is_bot = 0 AND browser != '' GROUP BY browser ORDER BY clicks DESC LIMIT 10",
          "editorMode": "code",
          "format": 0
        }
      ],
      "transformations": [
        { "id": "rowsToFields", "options": { "nameField": "browser", "valueField": "clicks" } }
      ],
      "options": {
        "pieType": "donut",
        "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] },
        "tooltip": { "mode": "single" }
      },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Chrome"          }, "properties": [{ "id": "color", "value": { "fixedColor": "#4285F4", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Firefox"         }, "properties": [{ "id": "color", "value": { "fixedColor": "#FF6611", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Safari"          }, "properties": [{ "id": "color", "value": { "fixedColor": "#0CB0E8", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Edge"            }, "properties": [{ "id": "color", "value": { "fixedColor": "#0F7B0F", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Samsung Browser" }, "properties": [{ "id": "color", "value": { "fixedColor": "#1428A0", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Other"           }, "properties": [{ "id": "color", "value": { "fixedColor": "#A78BFA", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "unknown"         }, "properties": [{ "id": "color", "value": { "fixedColor": "#94A3B8", "mode": "fixed" } }] }
        ]
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Browser Trend Over Time",
      "description": "Click volume by browser over time (bots excluded). Uses countIf to pivot browser into separate series.",
      "gridPos": { "h": 14, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT $__timeInterval(timestamp) AS time, countIf(browser = 'Chrome') AS Chrome, countIf(browser = 'Firefox') AS Firefox, countIf(browser = 'Safari') AS Safari, countIf(browser = 'Edge') AS Edge, countIf(browser = 'Samsung Browser') AS Samsung, countIf(browser NOT IN ('Chrome','Firefox','Safari','Edge','Samsung Browser') AND browser != '' AND browser != 'unknown' AND browser != 'bot') AS Other FROM shortener.clicks WHERE $__timeFilter(timestamp) AND user_id LIKE '$user_id' AND is_bot = 0 AND browser != '' GROUP BY time ORDER BY time ASC",
          "editorMode": "code",
          "format": 1
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 10, "lineWidth": 2, "drawStyle": "line", "stacking": { "mode": "none" } },
          "color": { "mode": "palette-classic" }
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 3,
      "type": "bargauge",
      "title": "Top Browsers (Total)",
      "description": "Cumulative clicks per browser for the selected period",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 14 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT browser, count() AS clicks FROM shortener.clicks WHERE $__timeFilter(timestamp) AND user_id LIKE '$user_id' AND is_bot = 0 AND browser != '' GROUP BY browser ORDER BY clicks DESC LIMIT 15",
          "editorMode": "code",
          "format": 0
        }
      ],
      "transformations": [
        { "id": "rowsToFields", "options": { "nameField": "browser", "valueField": "clicks" } }
      ],
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showUnfilled": true
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "continuous-BlPu" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        }
      }
    }
  ]
}
