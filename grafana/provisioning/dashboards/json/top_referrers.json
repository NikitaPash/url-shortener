{
  "uid": "top-referrers",
  "title": "Top Referrer Sources",
  "tags": ["url-shortener"],
  "timezone": "utc",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-7d", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "user_id",
        "label": "User",
        "type": "query",
        "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
        "query": "SELECT DISTINCT user_id FROM shortener.clicks ORDER BY user_id",
        "refresh": 2,
        "includeAll": true,
        "allValue": "%",
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "multi": false,
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "barchart",
      "title": "Top Referrer Sources",
      "description": "Where traffic is coming from (top 10 domains)",
      "gridPos": { "h": 14, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT CASE WHEN referrer = '' THEN '(direct)' ELSE domain(referrer) END AS source, count() AS clicks FROM shortener.clicks WHERE $__timeFilter(timestamp) AND user_id LIKE '$user_id' GROUP BY source ORDER BY clicks DESC LIMIT 10",
          "editorMode": "code",
          "format": 0
        }
      ],
      "options": {
        "orientation": "horizontal",
        "xTickLabelRotation": 0,
        "xTickLabelSpacing": 200,
        "barRadius": 0.1,
        "groupWidth": 0.7,
        "barWidth": 0.97,
        "stacking": "none",
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single", "sort": "none" },
        "colorByField": "source"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "continuous-BlPu" },
          "custom": { "fillOpacity": 80, "gradientMode": "none", "hideFrom": { "legend": false, "tooltip": false, "viz": false } }
        },
        "overrides": []
      }
    }
  ]
}
